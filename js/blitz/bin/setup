#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

APP="blitz-signaling"
REGION="${FLY_REGION:-iad}"

echo "=== Creating Fly app: $APP ==="
fly apps create "$APP" --machines 2>/dev/null || echo "App $APP already exists, continuing..."

echo ""
echo "=== Provisioning Upstash Redis ==="
fly redis create --name "$APP-redis" --region "$REGION" --no-replicas 2>&1 | tee /tmp/blitz-redis-output.txt || true
REDIS_URL=$(grep -oP 'redis://\S+' /tmp/blitz-redis-output.txt | head -1 || true)
rm -f /tmp/blitz-redis-output.txt

if [ -n "$REDIS_URL" ]; then
  echo ""
  echo "=== Setting REDIS_URL ==="
  fly secrets set REDIS_URL="$REDIS_URL" -a "$APP" --stage
else
  echo ""
  echo "Could not auto-detect REDIS_URL from output."
  echo "Set it manually: fly secrets set REDIS_URL=redis://... -a $APP"
fi

if [ -n "${CF_TURN_TOKEN_ID:-}" ] && [ -n "${CF_TURN_API_TOKEN:-}" ]; then
  echo ""
  echo "=== Setting Cloudflare TURN credentials ==="
  fly secrets set CF_TURN_TOKEN_ID="$CF_TURN_TOKEN_ID" CF_TURN_API_TOKEN="$CF_TURN_API_TOKEN" -a "$APP" --stage
fi

echo ""
echo "=== Deploying ==="
fly deploy

echo ""
echo "=== Done ==="
echo "App URL: https://$APP.fly.dev"
echo ""
echo "To enable CD from GitHub Actions, add a deploy token:"
echo "  fly tokens create deploy -a $APP"
echo "  gh secret set FLY_API_TOKEN --repo <owner>/<repo>"
