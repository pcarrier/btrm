#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
./bin/build-browser
cargo build --release --target x86_64-unknown-linux-musl -p blit-server -p blit-gateway -p blit-demo
echo "built: target/x86_64-unknown-linux-musl/release/blit-server target/x86_64-unknown-linux-musl/release/blit-gateway target/x86_64-unknown-linux-musl/release/chaos"
