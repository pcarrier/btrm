{
  "name": "@blit-sh/solid",
  "version": "0.20.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    }
  },
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./hooks": {
        "types": "./dist/hooks/index.d.ts",
        "default": "./dist/hooks/index.js"
      }
    }
  },
  "description": "Low-latency terminal streaming — Solid components and primitives",
  "homepage": "https://blit.sh",
  "author": "Indent <oss@indent.com> (https://indent.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indent-com/blit.git",
    "directory": "js/solid"
  },
  "bugs": {
    "url": "https://github.com/indent-com/blit/issues"
  },
  "keywords": [
    "terminal",
    "tty",
    "solid",
    "solidjs",
    "streaming",
    "webgl"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@blit-sh/core": "workspace:*",
    "solid-js": ">=1.8.0"
  },
  "devDependencies": {
    "@blit-sh/core": "workspace:*",
    "@blit-sh/browser": "file:../../crates/browser/pkg",
    "@solidjs/testing-library": "^0.8",
    "jsdom": "^29",
    "solid-js": "^1.9.0",
    "typescript": "^6",
    "vite-plugin-solid": "^2",
    "vitest": "^4"
  },
  "license": "MIT"
}
