{
  "name": "blit-react",
  "version": "0.16.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./transports": {
      "types": "./dist/transports/index.d.ts",
      "default": "./dist/transports/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./palettes": {
      "types": "./dist/palettes.d.ts",
      "default": "./dist/palettes.js"
    }
  },
  "description": "Low-latency terminal streaming — React components and hooks",
  "homepage": "https://blit.sh",
  "author": "Indent <oss@indent.com> (https://indent.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indent-com/blit.git",
    "directory": "js/react"
  },
  "bugs": {
    "url": "https://github.com/indent-com/blit/issues"
  },
  "keywords": [
    "terminal",
    "tty",
    "react",
    "streaming",
    "webgl"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "blit-browser": ">=0.9.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "blit-browser": "file:../../crates/browser/pkg",
    "jsdom": "^29",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^6",
    "@vitest/coverage-v8": "^4",
    "vitest": "^4"
  },
  "license": "MIT",
  "overrides": {
    "rollup": ">=4.59.0"
  }
}
