---
import JoinForm from "./JoinForm.tsx";
import CopyButton from "./CopyButton.tsx";

const INSTALL_CMD = "curl -f https://install.blit.sh | sh";
const DOCKER_CMD = "docker run --rm grab/blit-demo";
---

<section class="pt-14 pb-6">
  <h1
    class="text-[clamp(1.6rem,4vw,2.4rem)] font-bold leading-tight tracking-tight text-[var(--bright)]"
  >
    Your terminal, everywhere.
  </h1>
  <p class="mt-3 text-[13px] leading-relaxed text-[var(--dim)] max-w-[44rem]">
    Low-latency terminal streaming to any browser. Share with a link. Let AI
    agents drive them.
    <br />
    One binary, zero config, instant.
  </p>
  <p class="mt-2 text-xs text-[var(--dim)] opacity-70">
    MIT-licensed. Wide chars, emoji, and Unicode done right. Every unsafe block
    <a
      href="https://github.com/indent-com/blit/blob/main/UNSAFE.md"
      target="_blank"
      rel="noopener noreferrer"
      class="text-[var(--accent)] no-underline hover:underline">audited</a
    >, every invariant documented.
  </p>

  <div class="mt-8 flex gap-3 max-sm:flex-col">
    <div
      class="flex-1 bg-[var(--surface)] border border-[var(--border)] rounded-md px-4 py-3"
    >
      <div
        class="text-[11px] font-bold uppercase tracking-wider text-[var(--dim)] mb-2"
      >
        Install
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[var(--green)] select-none shrink-0">$</span>
        <span class="flex-1 min-w-0">{INSTALL_CMD}</span>
        <CopyButton text={INSTALL_CMD} client:load />
      </div>
    </div>

    <div
      class="flex-1 bg-[var(--surface)] border border-[var(--border)] rounded-md px-4 py-3"
    >
      <div
        class="text-[11px] font-bold uppercase tracking-wider text-[var(--dim)] mb-2"
      >
        Try it without installing
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[var(--green)] select-none shrink-0">$</span>
        <span class="flex-1 min-w-0">{DOCKER_CMD}</span>
        <CopyButton text={DOCKER_CMD} client:load />
      </div>
    </div>
  </div>

  <div class="mt-6">
    <div class="text-[13px] text-[var(--dim)] mb-1.5">
      or join an existing session
    </div>
    <JoinForm client:load />
  </div>
</section>
