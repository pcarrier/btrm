---
import ThemeToggle from "./ThemeToggle.tsx";
---

<header
  class="flex items-center justify-between px-6 py-2.5 border-b border-[var(--border)] bg-[var(--surface)] sticky top-0 z-10"
>
  <div class="flex items-center gap-2">
    <svg viewBox="0 0 100 100" width="24" height="24">
      <rect
        width="100"
        height="100"
        rx="16"
        fill="currentColor"
        class="text-[var(--fg)]"></rect>
      <text
        x="12"
        y="76"
        font-family="monospace"
        font-size="72"
        font-weight="bold"
        fill="var(--bg)">b</text
      >
      <rect
        x="60"
        y="24"
        width="8"
        height="52"
        rx="2"
        fill="var(--accent)"
        opacity="0.7"></rect>
    </svg>
    <span class="font-bold text-base tracking-tight">blit</span>
  </div>
  <nav class="flex items-center gap-4">
    <a
      href="https://github.com/indent-com/blit"
      target="_blank"
      rel="noopener noreferrer"
      class="text-[var(--dim)] text-[13px] no-underline hover:text-[var(--fg)] transition-colors"
    >
      GitHub
    </a>
    <ThemeToggle client:load />
  </nav>
</header>
