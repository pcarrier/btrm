#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

# Build WASM module
(cd crates/browser && wasm-pack build --target web --release --out-dir pkg)

# Install JS dependencies and build web app
(cd js/web-app && npm install --prefer-offline && npm run build)
(cd js/website && npm install --prefer-offline)
